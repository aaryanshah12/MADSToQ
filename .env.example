# Copy this file to .env.local and fill in your values
# .env.local is gitignored and will never be pushed to GitHub

# Supabase (get these from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# SMTP (for sending inquiry emails from inquires@madstoq.com)
# Gmail: generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=inquires@madstoq.com
SMTP_PASS=your-16-char-app-password

# Email address that receives all website inquiries (used by /api/send-inquiry).
INQUIRY_TO=inquires@madstoq.com

# SMTP for the Sales module (sends quotations / POs from sales@madstoq.com).
# Each value falls back to the matching SMTP_* above when unset, so if both
# mailboxes are on the same provider you only need to set USER + PASS.
SALES_SMTP_HOST=
SALES_SMTP_PORT=
SALES_SMTP_USER=sales@madstoq.com
SALES_SMTP_PASS=your-sales-app-password
# Note: the visible From and the CC (inquires@madstoq.com) are stored in
# sales_orgs.email_from / sales_orgs.email_cc — not here.

SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

