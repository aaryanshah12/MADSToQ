{
  "name": "madstoq-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "database"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo run build --filter=@madstoq/standard-erp",
    "start": "npm run start --workspace=@madstoq/standard-erp",
    "lint": "turbo lint",
    "generate-favicon": "node scripts/generate-favicon.js",
    "pmc:register-user": "node scripts/register-pmc-user.js"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
